{
  "name": "luxe-fashion",
  "version": "1.0.0",
  "private": true,
  "description": "LUXE — static fashion storefront",
  "scripts": {
    "templates": "node scripts/build-templates.js",
    "poster": "node scripts/build-poster.js",
    "build": "node scripts/build-templates.js && tailwindcss -i ./src/input.css -o ./dist/styles.css --minify",
    "watch": "tailwindcss -i ./src/input.css -o ./dist/styles.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
